{
  //
  // ------------------------------------------------------------------------
  // General settings
  // ------------------------------------------------------------------------
  // Breadcrumbs are pretty nice even if I don't use them much
  "breadcrumbs.enabled": true,
  // I'll put breakpoints where I want even if it doesn't make sense
  "debug.allowBreakpointsEverywhere": true,
  // Don't really remember this one but we'll keep it
  "explorer.confirmDragAndDrop": false,
  // Please god jesus stop bugging me about extension recommendations I don't
  // care
  "extensions.ignoreRecommendations": true,
  // Vagrantfiles are ruby scripts because of course they are
  "files.associations": {
    "Vagrantfile": "ruby",
    "*.ndjson": "json"
  },
  // Ignore files to reduce errors about tracking files
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.hg/store/**": true,
    "**/target/**": true
  },
  // Peroidically run a git fetch
  "git.autofetch": true,
  // Let me compose my own commits in peace thank you
  "git.suggestSmartCommit": false,
  // Disable telemetry
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  "workbench.enableExperiments": false,
  // Better title bars everywhere
  "window.titleBarStyle": "custom",
  //
  // ------------------------------------------------------------------------
  // Editor customizations
  // ------------------------------------------------------------------------
  // Help me out with brackets please
  "editor.guides.bracketPairs": "active",
  // Display trailing whitespace so it can be removed
  "editor.renderWhitespace": "trailing",
  // Automatically fix unusual line terminators
  "editor.unusualLineTerminators": "auto",
  // Configure rulers so I know when I'm writing a line too long
  "editor.rulers": [
    79,
    99,
    119
  ],
  // Set the font size just right
  "editor.fontSize": 13,
  // Minimap just takes up screen real estate
  "editor.minimap.enabled": false,
  // Autoformat code when possible
  "editor.formatOnSave": true,
  // Customize font
  "editor.fontFamily": "'Recursive Mono Casual Static'",
  "terminal.integrated.fontFamily": "'RecMonoCasual Nerd Font Mono'",
  // Font ligatures combine adjacent characters into a single cool character
  "editor.fontLigatures": true,
  "editor.suggestSelection": "first",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        // Turn off italic comments
        "scope": "comment",
        "settings": {
          "fontStyle": ""
        }
      },
      {
        // Fix python docstring colors
        "scope": [
          "string.quoted.docstring.multi.python",
          "string.quoted.docstring.multi.python punctuation.definition.string.begin.python",
          "string.quoted.docstring.multi.python punctuation.definition.string.end.python"
        ],
        "settings": {
          "foreground": "#5C6370"
        }
      },
      {
        "scope": "variable.key.table",
        "settings": {
          "foreground": "#39bae6"
        }
      },
      {
        "scope": "variable.key.array",
        "settings": {
          "foreground": "#39bae6"
        }
      },
      {
        "scope": "constant.other.time",
        "settings": {
          "foreground": "#d2a6ff"
        }
      }
    ]
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  // Don't try to auto-detect indentation, it goes bad sometimes
  "editor.detectIndentation": false,
  "workbench.iconTheme": "material-icon-theme",
  //
  // ------------------------------------------------------------------------
  // Language-specific settings
  // ------------------------------------------------------------------------
  // --- Docker Compose -----------------------------------------------------
  "[dockercompose]": {
    "editor.tabSize": 2
  },
  // --- CSS ----------------------------------------------------------------
  "[css]": {
    "editor.tabSize": 2
  },
  // --- Hashicorp Configuration Language -----------------------------------
  "[hcl]": {
    "editor.tabSize": 2
  },
  // --- Helm Templates -----------------------------------------------------
  "[helm]": {
    "editor.tabSize": 2
  },
  // --- HTML ---------------------------------------------------------------
  "[html]": {
    "editor.tabSize": 2,
    "rewrap.autoWrap.enabled": false,
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  // --- HTTP ---------------------------------------------------------------
  "[http]": {
    "files.eol": "\r\n"
  },
  // --- JavaScript ---------------------------------------------------------
  "[javascript]": {
    "editor.tabSize": 2
  },
  // --- Jinja2 -------------------------------------------------------------
  "[jinja]": {
    "rewrap.autoWrap.enabled": false
  },
  // --- JSX ----------------------------------------------------------------
  "[javascriptreact]": {
    "editor.tabSize": 2
  },
  // --- JSON ---------------------------------------------------------------
  "[json]": {
    "editor.tabSize": 2,
    "editor.wordWrap": "on",
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  // --- JSON with Comments -------------------------------------------------
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  // -- LaTeX ---------------------------------------------------------------
  "[latex]": {
    // The autoformatting for tables is pretty garbage when you have long lines
    "editor.formatOnSave": false,
    "editor.wordWrap": "on",
    "rewrap.autoWrap.enabled": false
  },
  // --- Markdown -----------------------------------------------------------
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 2,
    "rewrap.autoWrap.enabled": false
  },
  // --- Protocol Buffers ---------------------------------------------------
  "[proto3]": {
    "editor.tabSize": 2
  },
  // --- Python -------------------------------------------------------------
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    // Customize the rulers to look right with Black
    "editor.rulers": [
      88
    ],
    "editor.tabSize": 4,
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "python.experiments.optInto": [
    "pythonTestAdapter"
  ],
  // --- ReStructuredText ---------------------------------------------------
  "[restructuredtext]": {
    "editor.tabSize": 3,
    "editor.wordWrap": "on"
  },
  // --- Ruby ---------------------------------------------------------------
  "[ruby]": {
    "editor.tabSize": 2
  },
  // --- Rust ---------------------------------------------------------------
  // Enable proc macro support
  "rust-analyzer.procMacro.enable": true,
  // Only group imports at the module level
  "rust-analyzer.imports.granularity.enforce": true,
  "rust-analyzer.imports.granularity.group": "module",
  "[rust]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.formatOnSave": true,
    // Use the formatter shipped with rust-analyzer
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    // Customize the rulers to indicate the default max_width of rustfmt
    "editor.rulers": [
      100
    ],
    "rewrap.wrappingColumn": 80
  },
  // --- SCSS ---------------------------------------------------------------
  "[scss]": {
    "editor.tabSize": 2
  },
  // --- Shell scripts ------------------------------------------------------
  "[shellscript]": {
    "editor.tabSize": 2
  },
  // --- Terraform ----------------------------------------------------------
  "[tf]": {
    "editor.tabSize": 2
  },
  "[opentofu]": {
    "editor.tabSize": 2
  },
  // --- TypeScript ---------------------------------------------------------
  "[typescript]": {
    "editor.tabSize": 2
  },
  // --- TSX ----------------------------------------------------------------
  "[typescriptreact]": {
    "editor.tabSize": 2
  },
  // --- YAML ---------------------------------------------------------------
  "[yaml]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 2,
    "rewrap.autoWrap.enabled": false
  },
  "yaml.schemas": {
    "https://squidfunk.github.io/mkdocs-material/schema.json": "mkdocs.yml",
  },
  // --- XML ----------------------------------------------------------------
  "[xml]": {
    "rewrap.autoWrap.enabled": false,
    "xmlTools.enforcePrettySelfClosingTagOnFormat": true
  },
  // --- Bind9 DNS Zone -----------------------------------------------------
  "[zone]": {
    "editor.tabSize": 8,
    "editor.insertSpaces": false
  },
  //
  // ------------------------------------------------------------------------
  // Extension settings
  // ------------------------------------------------------------------------
  // Generate Python docstrings using numpy format without putting types in the
  // docstring itself. Sphinx will read typehints for you so you don't need to
  // put them in the docstring as well. Also, numpy's docstring format is
  // rendered better by vscode in previews by default.
  "autoDocstring.docstringFormat": "numpy-notypes",
  // Show test coverage on the lines, not the gutters
  "coverage-gutters.showGutterCoverage": false,
  "coverage-gutters.showLineCoverage": true,
  // Don't show a confirmation window to sync changes
  "git.confirmSync": false,
  // Default GitLens settings
  "gitlens.codeLens.enabled": false,
  "gitlens.defaultDateFormat": "YYYY MMMM Do - h:mma",
  "gitlens.defaultDateShortFormat": "YYYY MMM D",
  // Git repos are stored under ~/src; need to specify absolute path though
  "projectManager.git.baseFolders": [
    "$home/src"
  ],
  "projectManager.git.maxDepthRecursion": 1,
  // Manually set platforms for some remote ssh targets
  "dotfiles.repository": "s-newman/dotfiles",
  // https://github.com/microsoft/vscode-remote-release/issues/6333#issuecomment-1039210946
  "remote.SSH.localServerDownload": "always",
  // Automatically wrap comments as they get typed out
  "rewrap.autoWrap.enabled": true,
  // Configure Todo tree highlights
  "todo-tree.general.tags": [
    "BUG",
    "HACK",
    "FIXME",
    "TODO",
    "XXX",
    "todo!()",
    "[ ]",
    "[x]",
    "raise NotImplementedError()"
  ],
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^\\s*(-|\\d+.))\\s*($TAGS)",
  "window.zoomLevel": 1,
  "gitlens.launchpad.indicator.enabled": false,
  "vs-kubernetes": {
    "disable-linters": [
      "resource-limits"
    ]
  },
  "workbench.colorTheme": "Ayu Mirage Bordered",
  "chat.commandCenter.enabled": false,
  "git.openRepositoryInParentFolders": "never",
  "go.toolsManagement.autoUpdate": true,
  "workbench.editor.empty.hint": "hidden",
  "lldb.suppressUpdateNotifications": true,
  "docker.extension.enableComposeLanguageServer": false,
  "docker.lsp.experimental.vulnerabilityScanning": false,
  "git.blame.editorDecoration.enabled": true,
  "mise.binPath": "/opt/homebrew/bin/mise"
}