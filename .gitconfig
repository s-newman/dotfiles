[user]
    name = Sean Newman
    email = sean@snewman.co

[merge]
    ff = only

[pull]
    ff = only

[init]
    defaultBranch = main

[core]
    excludesfile = ~/.gitignore-global

[alias]
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --branches
